# Copy this file to .env and replace the placeholder values.
# Keep .env local. Do not commit real API keys.

FIRECRAWL_API_KEY=

# Optional OpenAI-compatible model API settings for generation evaluation.
GEO_LLM_PROVIDER=openai
GEO_LLM_MODEL=gpt-4o-mini
GEO_LLM_BASE_URL=
GEO_LLM_API_KEY=

# Optional AWS cloud corpus settings.
# Use an IAM user access key, not a root user access key.
AWS_REGION=ap-northeast-1
AWS_DEFAULT_REGION=ap-northeast-1
S3_BUCKET=geo-resource-library-prod-940329548423-ap-northeast-1-an
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# PostgreSQL connection string. Keep the real password only in .env.
DATABASE_URL=postgresql://USER:PASSWORD@geo-postgres-prod.cbkgwuwamngl.ap-northeast-1.rds.amazonaws.com:5432/postgres?sslmode=require
